# Server
PORT=5000

# SQL settings (sqlite for local development)
DB_DIALECT=sqlite
DB_STORAGE=database.sqlite

# If you prefer MySQL/Postgres, set DB_DIALECT and these:
# DB_NAME=patent_db
# DB_USER=root
# DB_PASS=secret
# DB_HOST=127.0.0.1
# DB_PORT=3307

# Optional: set a custom admin user/password for seed script
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=password
